PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=production
SESSION_DRIVER=cookie
URL=https://nomad.vanillax.me
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_DATABASE=nomad
DB_SSL=false
REDIS_HOST=redis
REDIS_PORT=6379
NOMAD_STORAGE_PATH=/app/storage
# Upstream v1.31.0 enables gzip compression in the admin app by default.
# Cilium gateway-external also gzips; double-compress is a no-op so leaving on.
DISABLE_COMPRESSION=false
LLM_PROVIDER=openai
LLM_HOST=http://llama-cpp-service.llama-cpp.svc.cluster.local:8080/v1
LLM_API_KEY=unused
AI_BENCHMARK_MODEL=qwen3.6-27b
EMBEDDING_HOST=http://embeddings.project-nomad.svc.cluster.local:8080/v1
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_DIMENSIONS=768
EMBEDDING_SEARCH_DOC_PREFIX=search_document: 
EMBEDDING_SEARCH_QUERY_PREFIX=search_query: 
QDRANT_HOST=http://qdrant.project-nomad.svc.cluster.local:6333
KIWIX_URL=https://kiwix.vanillax.me
CYBERCHEF_URL=https://cyberchef.vanillax.me
FLATNOTES_URL=https://flatnotes.vanillax.me
PROTOMAPS_URL=http://protomaps.project-nomad.svc.cluster.local:8080
